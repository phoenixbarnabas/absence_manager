{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<TENANT_ID>",
    "ClientId": "<CLIENT_ID>",
    "Audience": "<AUDIENCE>",
    "ClientSecret": "<CLIENT_SECRET>"
  },
  "Graph": {
    "BaseUrl": "https://graph.microsoft.com/v1.0",
    "Scopes": "User.Read"
  },
  "Email": {
    "Enabled": false,
    "Provider": "Smtp",
    "FromAddress": "noreply@tavolletkezelo.hu",
    "FromName": "Távollétkezelő",
    "FrontendBaseUrl": "http://localhost:4200",
    "ApprovalTokenExpirationHours": 72,
    "MaxRetryCount": 3,
    "Smtp": {
      "Host": "",
      "Port": 25,
      "EnableSsl": true,
      "UseDefaultCredentials": false,
      "Username": "",
      "Password": "",
      "TimeoutMilliseconds": 300000
    }
  }
}
